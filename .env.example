# Anthropic — required for POST /api/generate (email draft generation).
# Server-side only. Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GitHub OAuth — connect GitHub in Settings (no manual token when configured).
# Create an app at https://github.com/settings/developers
# Set callback URL to <your-domain>/api/auth/github/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Linear OAuth — connect Linear in Settings (no manual token when configured).
# Create an app at https://linear.app/settings/api/applications
# Set callback URL to <your-domain>/api/auth/linear/callback
NEXT_PUBLIC_LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Supabase — required for encrypted token storage.
# Create a project at https://supabase.com/dashboard and run:
# - supabase/migrations/001_tokens.sql
# - supabase/migrations/002_auth_user_scope.sql
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Token encryption key — 32-byte hex string (64 hex chars) for AES-256-GCM.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Loops — app now supports per-user API key in Settings.
# Optional global fallback key if a user has not saved one:
# LOOPS_API_KEY=
LOOPS_TRANSACTIONAL_ID=
# LOOPS_RECIPIENT_EMAIL=
