# Required for POST /api/generate (email draft generation).
# Get a key at https://platform.openai.com/api-keys
# Can also be provided via the Settings panel in the UI.
OPENAI_API_KEY=

# Optional: GitHub repo for PR sync (defaults to getcaddy/caddy)
# GITHUB_CADDY_REPO=getcaddy/caddy

# GitHub OAuth — create an app at https://github.com/settings/developers
# Set callback URL to <your-domain>/api/auth/github/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID="Ov23li6aAEwoaUAoDYlq"
GITHUB_CLIENT_SECRET=

# Linear OAuth — create an app at https://linear.app/settings/api/applications
# Set callback URL to <your-domain>/api/auth/linear/callback
NEXT_PUBLIC_LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
